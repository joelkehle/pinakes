# Non-secret deployment template. Copy this file once per independently
# operated bus domain, for example .env.ucla and .env.jk.
#
# Topology values may be committed after host verification. Never put tokens,
# passwords, agent secrets, or other credentials in these files.

PINAKES_TAG=
BUS_PORT=
BUS_DATA_VOLUME=
STACK_NETWORK_NAME=
MANAGER_CONFIG_DIR=
GOMEMLIMIT=
BUS_MEMORY_LIMIT=

# Secret values must be supplied only in the operator shell or a gitignored
# local env file at config-check/deploy time. Never commit live values.
INJECT_TOKENS=
OBSERVE_TOKENS=
