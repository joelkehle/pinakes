# Standalone UCLA pinakes bus stack.
# These keys moved out of ucla-tdg-ip-agents/deploy/.env into this file.
# All other keys stay in the IP-agents stack: ANTHROPIC_API_KEY, *_AGENT_SECRET,
# LANGFUSE_*, OTEL_*, OPERATOR_*, PRIOR_ART_*, and PATENT_*.

# Optional. Pinakes image tag.
PINAKES_TAG=v0.3.0

# Optional. Published host port. Consumers depend on :8080; do not change
# without coordinating every host.docker.internal and bus URL consumer.
BUS_PORT=8080

# Optional. Live value is /data/pinakes.db.
PINAKES_DB_PATH=/data/pinakes.db

# Required. Inject-endpoint auth token. Reuse the live UCLA bus value.
PINAKES_INJECT_TOKEN=replace-with-inject-token

# Required. Observe-endpoint auth token. Reuse the live UCLA bus value.
PINAKES_OBSERVE_TOKEN=replace-with-observe-token

# Optional. Must match the live external network shared with the IP-agents and
# Langfuse stacks.
STACK_NETWORK_NAME=tta-agentnet
