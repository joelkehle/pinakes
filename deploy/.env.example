# Non-secret deployment template. Copy this file once per independently
# operated bus domain, for example .env.ucla and .env.jk.
#
# Topology and resource values may be committed after host verification. Never
# put tokens, passwords, agent secrets, or other credentials in these files.
# PINAKES_INJECT_TOKEN and PINAKES_OBSERVE_TOKEN are required by the compose
# file, but must be exported in the deploying shell or supplied through a
# gitignored environment file.

PINAKES_TAG=
BUS_PORT=
BUS_DATA_VOLUME=
STACK_NETWORK_NAME=
MANAGER_CONFIG_DIR=
PINAKES_DB_PATH=
BUS_MEMORY_LIMIT=
GOMEMLIMIT=
